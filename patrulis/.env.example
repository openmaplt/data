# Environment variables placeholder

# Connection string for PostgreSQL
DATABASE_URL="postgresql://[username]:[password]@localhost:5434/[database]"

# OSM OAuth 2.0 (register at https://www.openstreetmap.org/oauth2/applications/new)
# Redirect URI to register: https://[your-domain]/api/auth/callback
OSM_CLIENT_ID="your_client_id"
OSM_CLIENT_SECRET="your_client_secret"

# Public URL of the app (required in production behind a reverse proxy)
# Leave empty for local development — falls back to request origin automatically
APP_URL="https://your-domain.com"

# Session encryption key — generate with: openssl rand -hex 32
SESSION_SECRET="at_least_32_random_characters_here"